# ══════════════════════════════════════════════
# PEMBAYARAN INVOICE BARU
# ══════════════════════════════════════════════
# PENTING: Jalankan nomor 5, 6, 7 dulu untuk membuat invoice baru.
#          Kemudian ambil invoiceId dari response masing-masing.
#
# Ganti {{invoiceId5}} dan {{invoiceId6}} di bawah dengan UUID
# yang dikembalikan oleh response POST di atas.

# 8. Bayar Invoice INV-2024-003 (Rp10.000.000) via Kas
# GANTI invoiceId di bawah dengan ID dari response nomor 5!
PUT http://localhost:8080/api/v1/invoices/df8ff68f-ccf0-4981-a6ff-0f86194ae453/pay
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJqaWthc2FAZ21haWwuY29tIiwiaWF0IjoxNzczMDI3MTkwLCJleHAiOjE3NzMxMTM1OTB9.TLcfDTBEnwtF6QA_3DbnMNs8sS2U-LDm-44hPkdcusA

{
  "amount": 10000000.0000,
  "accountId": "f7443618-d1d7-4068-a4e0-10f163e5ea64"
}

###

