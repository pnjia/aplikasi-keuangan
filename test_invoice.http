# 3. Mengambil Daftar Tagihan (Paginasi)
# Akses: OWNER, ADMIN, KASIR
# Gunakan query param page dan size untuk kontrol paginasi
GET http://localhost:8080/api/v1/invoices?page=0&size=10
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJqaWthc2FAZ21haWwuY29tIiwiaWF0IjoxNzczMDI3MTkwLCJleHAiOjE3NzMxMTM1OTB9.TLcfDTBEnwtF6QA_3DbnMNs8sS2U-LDm-44hPkdcusA

###

# 4. Memproses Pembayaran Tagihan (Pay Invoice)
# Akses: Hanya OWNER, ADMIN
# PENTING:
#   - Ganti {{invoiceId}} dengan UUID invoice dari response POST di atas
#   - Ganti {{accountId}} dengan UUID akun Kas atau Bank dari response GET /api/v1/accounts
#   - Endpoint ini akan OTOMATIS membuat jurnal ganda (double-entry) di database
PUT http://localhost:8080/api/v1/invoices/1f86e5f0-6b17-48bb-827b-a93179ff7a27/pay
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJqaWthc2FAZ21haWwuY29tIiwiaWF0IjoxNzczMDI3MTkwLCJleHAiOjE3NzMxMTM1OTB9.TLcfDTBEnwtF6QA_3DbnMNs8sS2U-LDm-44hPkdcusA

{
  "amount": 23000000.0000,
  "accountId": "f7443618-d1d7-4068-a4e0-10f163e5ea64"
}

