# ══════════════════════════════════════════════
# SKENARIO LABA RUGI (PROFIT AND LOSS)
# ══════════════════════════════════════════════
# Sekarang sistem otomatis mendeteksi Tipe Kontak:
# - CUSTOMER -> Mencatat "Pendapatan Jasa" (REVENUE)
# - VENDOR   -> Mencatat "Beban Operasional" (EXPENSE)

# 10. Invoice Konsultasi (Dari CUSTOMER) -> PENDAPATAN
POST http://localhost:8080/api/v1/invoices
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJqaWthc2FAZ21haWwuY29tIiwiaWF0IjoxNzczMDI3MTkwLCJleHAiOjE3NzMxMTM1OTB9.TLcfDTBEnwtF6QA_3DbnMNs8sS2U-LDm-44hPkdcusA

{
  "contactId": "61e48839-bd9b-4ab1-ba4a-4b592025b076",
  "invoiceNumber": "INV-2024-006",
  "issueDate": "2024-06-01T00:00:00Z",
  "dueDate": "2024-06-30T00:00:00Z",
  "status": "SENT",
  "items": [
    {
      "description": "Pendapatan Jasa Konsultasi",
      "quantity": 1,
      "unitPrice": 45000000.0000
    }
  ]
}

###

